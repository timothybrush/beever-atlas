{
  "name": "beever-atlas-bot",
  "version": "0.2.0",
  "description": "Beever Atlas Chat SDK bot for Slack and multi-platform chat",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "find src -name '*.test.ts' -exec tsx --test {} +",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@chat-adapter/discord": "4.29.0",
    "@chat-adapter/slack": "4.29.0",
    "@chat-adapter/state-redis": "4.29.0",
    "@chat-adapter/teams": "4.29.0",
    "@chat-adapter/telegram": "4.29.0",
    "chat": "4.29.0",
    "chat-adapter-mattermost": "1.1.3",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "tsx": "^4.19.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
